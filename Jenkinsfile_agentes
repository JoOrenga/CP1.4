pipeline {
    agent none

    environment {
        AWS_REGION   = 'us-east-1'
        SAM_TEMPLATE = 'template.yaml'
        SAM_CONFIG   = 'samconfig.toml'
    }

    stages {
        stage('Get Code') {
            agent { label 'aws3' }
            steps {
                sh'''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                    echo "STAGE: ${STAGE_NAME} / AGENTE: ${NODE_NAME}"
                '''
                git branch: 'master', url: 'https://github.com/JoOrenga/CP1.4.git'
                stash name: 'codigo', includes: '**/*'
            }
        }

        stage('Deploy') {
            agent { label 'aws2' }
            steps {
                unstash 'codigo'
                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                    echo "STAGE: ${STAGE_NAME} / AGENTE: ${NODE_NAME}"
                    S3_BUCKET=$(grep -A5 "\\[production.deploy.parameters\\]" ${SAM_CONFIG} \
                    | grep "s3_bucket" \
                    | cut -d'"' -f2)
                    aws s3api head-bucket --bucket ${S3_BUCKET} 2>/dev/null || \
                    aws s3api create-bucket \
                        --bucket ${S3_BUCKET} \
                        --region ${AWS_REGION}
                '''
                sh 'sam build -t ${SAM_TEMPLATE}'
                sh 'sam validate --region ${AWS_REGION}'
                sh 'sam deploy --config-env production --config-file ${SAM_CONFIG} --no-fail-on-empty-changeset'
        
                script {
                    def STACK_NAME = sh(
                            script: '''
                                grep -A5 "\\[production.deploy.parameters\\]" ${SAM_CONFIG}  \
                                | grep "stack_name" \
                                | cut -d'"' -f2
                            ''',
                            returnStdout: true
                    ).trim()
                    
                    env.BASE_URL = sh(
                        script: """
                            aws cloudformation describe-stacks \\
                                --stack-name ${STACK_NAME} \\
                                --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \\
                                --region ${AWS_REGION} \\
                                --output text
                        """,
                        returnStdout: true
                    ).trim()
        
                    echo "BASE_URL capturada: ${env.BASE_URL}"
                }
            }
        }
        
        stage('Rest Test') {
            agent { label 'aws3' }
            steps {
                unstash 'codigo'
                sh'''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                    echo "STAGE: ${STAGE_NAME} / AGENTE: ${NODE_NAME}"
                '''
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    sh """BASE_URL=${BASE_URL} pytest --junitxml=result-integration.xml -s \
                            -k 'test_api_listtodos or test_api_addtodo' \
                            test/integration/todoApiTest.py"""
                    
                }
                junit 'result-integration.xml'
            }
        }
    }

        post {
        always {
            node('aws1') {
                cleanWs(
                    deleteDirs: true,
                    disableDeferredWipeout: true,
                    notFailBuild: true
                )
            }
            node('aws2') {
                cleanWs(
                    deleteDirs: true,
                    disableDeferredWipeout: true,
                    notFailBuild: true
                )
            }
            node('aws3') {
                cleanWs(
                    deleteDirs: true,
                    disableDeferredWipeout: true,
                    notFailBuild: true
                )
            }
        }
    }
}